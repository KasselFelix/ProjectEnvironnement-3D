<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<!-- Code source -->
	<classpathentry kind="src" path="src"/>

	<!-- Tests JUnit 5 (sources isolées, sortie dans test/bin pour ne pas
	     mélanger les .class de test avec ceux de production dans bin/) -->
	<classpathentry kind="src" path="test/src" output="test/bin">
		<attributes>
			<attribute name="test" value="true"/>
		</attributes>
	</classpathentry>

	<!-- JRE container générique : référence "JavaSE-17", résolue côté
	     l'IDE qui ouvre le projet (VS Code via java.configuration.runtimes,
	     ou Eclipse via Window > Preferences > Java > Installed JREs). -->
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER/org.eclipse.jdt.internal.debug.ui.launcher.StandardVMType/JavaSE-17">
		<attributes>
			<attribute name="module" value="true"/>
		</attributes>
	</classpathentry>

	<!-- JOGL : on liste les jars directement (chemins relatifs au projet).
	     Marche tel quel après `git clone`, contrairement à une User Library
	     Eclipse qu'il faut configurer manuellement par développeur. -->
	<classpathentry kind="lib" path="JOGL/jar/gluegen-rt.jar"/>
	<classpathentry kind="lib" path="JOGL/jar/jogl-all.jar"/>
	<classpathentry kind="lib" path="JOGL/jar/gluegen-rt-natives-linux-amd64.jar"/>
	<classpathentry kind="lib" path="JOGL/jar/jogl-all-natives-linux-amd64.jar"/>
	<classpathentry kind="lib" path="JOGL/jar/gluegen-rt-natives-windows-amd64.jar"/>
	<classpathentry kind="lib" path="JOGL/jar/jogl-all-natives-windows-amd64.jar"/>
	<classpathentry kind="lib" path="JOGL/jar/gluegen-rt-natives-macosx-universal.jar"/>
	<classpathentry kind="lib" path="JOGL/jar/jogl-all-natives-macosx-universal.jar"/>

	<!-- JUnit 5 (test-only) — jars individuels téléchargés par ./test-setup.sh.
	     Le fat jar junit-platform-console-standalone-*.jar existe aussi
	     dans test/lib/ mais N'est PAS listé ici : il est utilisé seulement
	     par ./test.sh côté CLI ; sur le classpath IDE on préfère les jars
	     individuels (sinon le Test Runner for Java de VS Code n'arrive
	     pas à découvrir les classes JUnit dans le fat jar shaded).
	     Versions pinnées par test-setup.sh ; à mettre à jour ici si
	     elles changent. -->
	<classpathentry kind="lib" path="test/lib/junit-jupiter-api-5.10.2.jar">
		<attributes><attribute name="test" value="true"/></attributes>
	</classpathentry>
	<classpathentry kind="lib" path="test/lib/junit-jupiter-engine-5.10.2.jar">
		<attributes><attribute name="test" value="true"/></attributes>
	</classpathentry>
	<classpathentry kind="lib" path="test/lib/junit-platform-commons-1.10.2.jar">
		<attributes><attribute name="test" value="true"/></attributes>
	</classpathentry>
	<classpathentry kind="lib" path="test/lib/junit-platform-engine-1.10.2.jar">
		<attributes><attribute name="test" value="true"/></attributes>
	</classpathentry>
	<classpathentry kind="lib" path="test/lib/junit-platform-launcher-1.10.2.jar">
		<attributes><attribute name="test" value="true"/></attributes>
	</classpathentry>
	<classpathentry kind="lib" path="test/lib/opentest4j-1.3.0.jar">
		<attributes><attribute name="test" value="true"/></attributes>
	</classpathentry>
	<classpathentry kind="lib" path="test/lib/apiguardian-api-1.1.2.jar">
		<attributes><attribute name="test" value="true"/></attributes>
	</classpathentry>

	<!-- Sortie de compilation -->
	<classpathentry kind="output" path="bin"/>
</classpath>
